# ─── Turso Database ───────────────────────────────────────
# Get from: turso db show your-db --url
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# Get from: turso db tokens create your-db
TURSO_AUTH_TOKEN=your-auth-token-here

# ─── AI Providers (Free Tiers — Fallback Chain) ───────────
# PRIMARY: Groq — 14,400 req/day free
# Sign up at: console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# BACKUP: Gemini — 1,500 req/day free
# Sign up at: aistudio.google.com
GEMINI_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxx

# ─── Email ────────────────────────────────────────────────
# Sign up at: resend.com — 3,000 emails/month free
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
LEAD_NOTIFICATION_EMAIL=your@email.com

# ─── Payments (setup when ready) ──────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# ─── App ──────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yoursite.com
NEXT_PUBLIC_SITE_NAME=ImportDuty.in
